		Size = UDim2.fromOffset(394, 42),
		Position = UDim2.fromOffset(18, 187)
	})
	local release = TweenService:Create(sendButton, TweenInfo.new(0.1), {
		Size = UDim2.fromOffset(398, 44),
		Position = UDim2.fromOffset(16, 186)
	})

	press:Play()
	press.Completed:Wait()
	release:Play()

	task.delay(1, function()
