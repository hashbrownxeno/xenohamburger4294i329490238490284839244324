local function getColorName(value)
	if value < 0.18 then
		return "Warm"
	elseif value < 0.38 then
		return "Gold"
	elseif value < 0.58 then
		return "Fresh"
	elseif value < 0.78 then
		return "Cool"
	else
		return "Vivid"
	end
end

local function applyAccent(animate)
	local accent = getAccentColor()
	local dark = getAccentDark()
	local light = accent:Lerp(Color3.fromRGB(255, 255, 255), 0.16)

	sliderValueLabel.Text = getColorName(hue)

	if animate then
		TweenService:Create(sliderFill, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Size = UDim2.fromScale(hue, 1),
			BackgroundColor3 = accent,
		}):Play()

		TweenService:Create(sliderKnob, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.fromScale(hue, 0.5),
		}):Play()

		TweenService:Create(previewChip, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = accent,
		}):Play()

		TweenService:Create(sendButton, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundColor3 = accent,
		}):Play()
	else
		sliderFill.Size = UDim2.fromScale(hue, 1)
		sliderFill.BackgroundColor3 = accent
		sliderKnob.Position = UDim2.fromScale(hue, 0.5)
		previewChip.BackgroundColor3 = accent
		sendButton.BackgroundColor3 = accent
	end

	sendGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, light),
		ColorSequenceKeypoint.new(1, dark),
	})
end

local function updateSlider(mouseX)
	local left = sliderTrack.AbsolutePosition.X
	local width = sliderTrack.AbsoluteSize.X
	hue = math.clamp((mouseX - left) / width, 0, 1)
	applyAccent(true)
end

sliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		updateSlider(input.Position.X)
	end
end)

sliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		updateSlider(input.Position.X)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		updateSlider(input.Position.X)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

