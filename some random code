sendButton.MouseButton1Click:Connect(function()
	local text = textBox.Text
	if text == "" then
		text = "Nothing entered"
	end

	sendButton.Text = "Sent"
	messageLabel.Text = "Last message: " .. text
	print("Sent text:", text)

	local pressDown = TweenService:Create(sendButton, TweenInfo.new(0.08), {
		Size = UDim2.fromOffset(478, 46),
		Position = UDim2.fromOffset(31, 257),
	})

	local release = TweenService:Create(sendButton, TweenInfo.new(0.1), {
		Size = UDim2.fromOffset(484, 48),
		Position = UDim2.fromOffset(28, 256),
	})

	pressDown:Play()
	pressDown.Completed:Wait()
	release:Play()

	task.delay(1, function()
		if sendButton.Parent then
			sendButton.Text = "Send"
		end
	end)
end)

