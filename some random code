sendButton.MouseButton1Click:Connect(function()
	local message = textBox.Text
	if message == "" then
		message = "Nothing entered"
	end

	sendButton.Text = "Sent"
	sentLabel.Text = "Last message: " .. message
	print("Sent text:", message)

	local pressTween = TweenService:Create(sendButton, TweenInfo.new(0.08), {
		Size = UDim2.fromOffset(458, 40),
		Position = UDim2.fromOffset(31, 255),
	})
	local releaseTween = TweenService:Create(sendButton, TweenInfo.new(0.12), {
		Size = UDim2.fromOffset(464, 42),
		Position = UDim2.fromOffset(28, 254),
	})

	pressTween:Play()
	pressTween.Completed:Wait()
	releaseTween:Play()

	task.delay(1.1, function()
		if sendButton then
			sendButton.Text = "Send"
		end
	end)
end)

