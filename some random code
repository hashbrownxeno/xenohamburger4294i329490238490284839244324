local function applyAccent(animated)
	local accent = currentAccent()
	local darker = accent:Lerp(Color3.new(0, 0, 0), 0.22)
	local lighter = accent:Lerp(Color3.new(1, 1, 1), 0.18)

	local function set(obj, props)
		if animated then
			TweenService:Create(obj, TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
		else
			for k, v in pairs(props) do
				obj[k] = v
			end
		end
	end

	set(sliderFill, {BackgroundColor3 = accent, Size = UDim2.fromScale(hue, 1)})
	set(sliderKnob, {Position = UDim2.fromScale(hue, 0.5)})
	set(preview, {BackgroundColor3 = accent})
	set(sendButton, {BackgroundColor3 = accent})
	sendGradient.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, lighter),
		ColorSequenceKeypoint.new(1, darker),
	})
end

local function updateSliderFromX(x)
	local left = sliderTrack.AbsolutePosition.X
	local width = sliderTrack.AbsoluteSize.X
	hue = math.clamp((x - left) / width, 0, 1)
	applyAccent(true)
end

sliderTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		updateSliderFromX(input.Position.X)
	end
end)

sliderKnob.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		updateSliderFromX(input.Position.X)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		updateSliderFromX(input.Position.X)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

