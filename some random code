--- LOGIC ---

local function parse(text)
    local sz = sizeBox.Text ~= "" and sizeBox.Text or "30"
    local res = ""
    for i = 1, #text do
        res = res .. "<p><font size=\""..sz.."\">"..text:sub(i,i).."</font></p>"
    end
    return res
end

local function getRemote()
    return game:GetService("ReplicatedStorage"):FindFirstChild("SayMessageRequest", true) 
end

-- AUTO-CHAT HOOK
local hooking = false
autoChat.MouseButton1Click:Connect(function()
    hooking = not hooking
    autoChat.Text = hooking and "AUTO-CHAT: ON" or "AUTO-CHAT: OFF"
    autoChat.BackgroundColor3 = hooking and Color3.fromRGB(0, 100, 0) or Color3.fromRGB(40, 0, 0)
end)

game:GetService("Players").LocalPlayer.Chatted:Connect(function(msg)
    if hooking then
        local remote = getRemote()
        if remote then
            remote:FireServer(parse(msg), "All")
        end
    end
end)

-- SPAM LOGIC
local spanning = false
spamToggle.MouseButton1Click:Connect(function()
    spanning = not spanning
    spamToggle.Text = spanning and "STOP SPAM" or "START SPAM (0.1s)"
    if spanning then
        task.spawn(function()
            while spanning do
                local remote = getRemote()
                if remote then remote:FireServer(parse(spamInput.Text), "All") end
                task.wait(0.1)
            end
        end)
    end
end)
